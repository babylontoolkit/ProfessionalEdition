{
    "compilerOptions": {
        "experimentalDecorators": true,
        "target": "###ECMASCRIPT###",
        "lib": [
            "es5",
            "dom",
            "esnext",
            "es2015.promise",
            "es2015.collection",
            "es2015.iterable",
            "es2015.symbol.wellknown",
            "es2020.bigint"
        ],
        "allowJs": false,
        "declaration": true,
        "skipLibCheck": true,
        "strictNullChecks": false,
        "noImplicitAny": false,
        "inlineSources": ###SOURCEMAP###,
        "inlineSourceMap": ###SOURCEMAP###,
        "ignoreDeprecations": "6.0",
        "rootDir": "./Assets",
        "outFile": "###OUTFILE###"
    },
    "include": [
        "packages/**/*.d.ts",
        "library/**/*.d.ts",
        "assets/**/*.d.ts",
        "###XPATH###/**/*"
    ]    
}